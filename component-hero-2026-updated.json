umn", "_gap": "var(--at-space--xs)"}, "modified": 1773218959851, "user_id": 1}, {"id": "wyopqz", "name": "text-content", "settings": {"_cssCustom": ".text-content {\n\n  h2, h3, h4, h5, h6{\n  \tfont-weight: 700;\n    color: var(--at-black);\n    margin-bottom: var(--at-space--s);\n  }\n\n  h2{\n  \tfont-size: var(--at-heading--m);\n  }\n\n  h3{\n    font-size: var(--at-heading--s);\n  }\n\n  h4, h5, h6{\n  \tfont-size: var(--at-text--s);\n  }\n\n  p {\n\n    strong, bold{\n      color: var(--at-black);\n    }\n\n    a{\n     \tcolor: var(--at-primary);\n      transition: color .2s ease;\n\n      &:hover, &:focus{\n      \tcolor: var(--at-primary-d-1);\n        text-decoration: underline;\n      }\n    }\n\n  }\n\n  ul, ol{\n    margin:var(--at-space--m) 0;\n\n    ::marker{\n      color: var(--at-black);\n    }\n\n    li:not(:last-child){\n    \tmargin-bottom: 8px;\n    }\n  }\n}\n"}, "modified": 1764669813888, "user_id": 1}], "globalElements": []}